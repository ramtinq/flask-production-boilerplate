# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment variables (Crucial to ignore for security)
.env
.env.local

# Operating System files
.DS_Store
Thumbs.db

# Database files (Ignore temporary DB states, but KEEP the migrations/ folder!)
migrations/*.db
migrations/*.sqlite

# IDEs and editors
.vscode/
.idea/

# Docker local overrides (Keep the main compose file, ignore local changes)
docker-compose.override.yaml# Byte-compiled / optimized / DLL files
